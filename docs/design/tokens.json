{
  "name": "Amp Glow",
  "description": "Warm, dangerous light from a tube amp in the dark. GuitarHub design system.",
  "css_source": "src/lib/styles/design-tokens.css",
  "colors": {
    "void": {
      "deep": "#07070C",
      "mid": "#0F0F18",
      "raised": "#161622",
      "hover": "#1E1E2E",
      "active": "#252538"
    },
    "glow": {
      "primary": "#FF7A3D",
      "warm": "#FFB84D",
      "hot": "#FF4D4D",
      "cool": "#4DE1FF",
      "gold": "#FFD700",
      "soft": "rgba(255, 122, 61, 0.15)",
      "medium": "rgba(255, 122, 61, 0.3)",
      "intense": "rgba(255, 122, 61, 0.5)"
    },
    "text": {
      "bright": "#F5F0EB",
      "warm": "#C4B8A8",
      "dim": "#7A6E5E",
      "muted": "#4A4339"
    },
    "functional": {
      "success": "#00E676",
      "warning": "#FFB300",
      "danger": "#FF1744",
      "info": "#00B0FF"
    },
    "legacy_mapping": {
      "primary": "var(--glow-primary)",
      "surface": "var(--void-mid)",
      "on_surface": "var(--text-bright)"
    }
  },
  "spacing": {
    "base": "4px",
    "scale": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    },
    "aliases": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "40px"
    }
  },
  "radius": {
    "xs": "2px",
    "sm": "8px",
    "md": "12px",
    "lg": "20px",
    "xl": "28px",
    "pill": "9999px"
  },
  "fonts": {
    "display": "Space Grotesk",
    "body": "Inter",
    "mono": "JetBrains Mono",
    "accent": "Caveat",
    "sans": "Inter"
  },
  "transitions": {
    "fast": "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "base": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "300ms cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "easing": {
    "plug": "cubic-bezier(0.16, 1, 0.3, 1)",
    "strum": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "fade": "cubic-bezier(0.4, 0, 0.2, 1)",
    "snap": "cubic-bezier(0.7, 0, 0.3, 1)"
  },
  "shadows": {
    "card": "0 4px 24px rgba(0, 0, 0, 0.4)",
    "hover": "0 12px 48px rgba(0, 0, 0, 0.6), 0 0 0 1px var(--glow-soft), 0 0 30px var(--glow-soft)",
    "modal": "0 24px 64px rgba(0, 0, 0, 0.7)",
    "glow": "0 0 30px var(--glow-soft)"
  },
  "z_index": {
    "base": 0,
    "dropdown": 100,
    "sticky": 200,
    "overlay": 300,
    "modal": 400,
    "popover": 500,
    "toast": 600
  }
}
